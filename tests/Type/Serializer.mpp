export module CppUtils.UnitTests.Type.Serializer;

import std;
import CppUtils;
import CppUtils.Type.Serializer;

export namespace CppUtils::UnitTest::Type::Serializer
{
	struct CustomType final
	{
		int x;
		std::string y;

		auto operator==(const CustomType& other) const -> bool = default;
	};
}

namespace CppUtils::Type::Binary
{
	template<>
	struct Serializer<CppUtils::UnitTest::Type::Serializer::CustomType> final
	{
		static inline auto serialize(const CppUtils::UnitTest::Type::Serializer::CustomType& value, auto& target) -> void
		{
			Type::serialize(value.x, target);
			Type::serialize(value.y, target);
		}

		[[nodiscard]] static inline auto deserialize(auto& source, CppUtils::UnitTest::Type::Serializer::CustomType& value) -> std::expected<void, std::string_view>
		{
			auto resultX = Type::deserialize(source, value.x);
			if (not resultX)
				return std::unexpected{resultX.error()};

			auto resultY = Type::deserialize(source, value.y);
			if (not resultY)
				return std::unexpected{resultY.error()};

			return {};
		}

		[[nodiscard]] static inline auto deserialize(auto& source) -> std::expected<CppUtils::UnitTest::Type::Serializer::CustomType, std::string_view>
		{
			auto value = CppUtils::UnitTest::Type::Serializer::CustomType{};
			auto result = deserialize(source, value);
			if (not result)
				return std::unexpected{result.error()};
			return value;
		}
	};
}

export namespace CppUtils::UnitTest::Type::Serializer
{
	auto _ = TestSuite{"Type/Serializer", [](TestSuite& suite) {
		using namespace std::literals;

		suite.addTest("Trivial Type", [&suite] {
			auto value = 42;
			auto buffer = CppUtils::Type::serialize(value);

			{
				auto view = std::span<const std::byte>{buffer};
				auto result = CppUtils::Type::deserialize<int>(view);
				suite.expect(result.has_value());
				suite.expectEqual(result.value(), value);
			}

			{
				auto view = std::span<const std::byte>{buffer};
				auto deserializedValue = 0;
				auto result = CppUtils::Type::deserialize(view, deserializedValue);
				suite.expect(result.has_value());
				suite.expectEqual(deserializedValue, value);
			}
		});

		suite.addTest("std::string", [&suite] {
			auto value = "Hello World!"s;
			auto buffer = CppUtils::Type::serialize(value);

			{
				auto view = std::span<const std::byte>{buffer};
				auto result = CppUtils::Type::deserialize<std::string>(view);
				suite.expect(result.has_value());
				suite.expectEqual(result.value(), value);
			}

			{
				auto view = std::span<const std::byte>{buffer};
				auto deserializedValue = ""s;
				auto result = CppUtils::Type::deserialize(view, deserializedValue);
				suite.expect(result.has_value());
				suite.expectEqual(deserializedValue, value);
			}
		});

		suite.addTest("std::vector", [&suite] {
			auto value = std::vector<int>{1, 2, 3, 4, 5};
			auto buffer = CppUtils::Type::serialize(value);

			{
				auto view = std::span<const std::byte>{buffer};
				auto result = CppUtils::Type::deserialize<std::vector<int>>(view);
				suite.expect(result.has_value());
				suite.expectEqual(result.value(), value);
			}

			{
				auto view = std::span<const std::byte>{buffer};
				auto deserializedValue = std::vector<int>{};
				auto result = CppUtils::Type::deserialize(view, deserializedValue);
				suite.expect(result.has_value());
				suite.expectEqual(deserializedValue, value);
			}
		});

		suite.addTest("Custom Type", [&suite] {
			auto value = CustomType{42, "Hello"};
			auto buffer = CppUtils::Type::serialize(value);

			{
				auto view = std::span<const std::byte>{buffer};
				auto result = CppUtils::Type::deserialize<CustomType>(view);
				suite.expect(result.has_value());
				suite.expectEqual(result.value(), value);
			}

			{
				auto view = std::span<const std::byte>{buffer};
				auto deserializedValue = CustomType{};
				auto result = CppUtils::Type::deserialize(view, deserializedValue);
				suite.expect(result.has_value());
				suite.expectEqual(deserializedValue, value);
			}
		});

		suite.addTest("TextSerializer (Basic)", [&suite] {
			auto value = 42;
			auto buffer = ""s;
			CppUtils::Type::Text::Serializer<int>::serialize(value, buffer);

			{
				auto view = std::string_view{buffer};
				auto result = CppUtils::Type::Text::Serializer<int>::deserialize(view);
				suite.expect(result.has_value());
				suite.expectEqual(result.value(), value);
				suite.expectEqual(view, ""sv);
			}

			{
				auto view = std::string_view{buffer};
				auto deserializedValue = 0;
				auto result = CppUtils::Type::Text::Serializer<int>::deserialize(view, deserializedValue);
				suite.expect(result.has_value());
				suite.expectEqual(deserializedValue, value);
				suite.expectEqual(view, ""sv);
			}
		});

		suite.addTest("TextSerializer (Multiple)", [&suite] {
			auto value0 = 3.14;
			auto value1 = 42;
			auto buffer = ""s;
			CppUtils::Type::Text::Serializer<double>::serialize(value0, buffer);
			CppUtils::Type::Text::Serializer<int>::serialize(value1, buffer);

			auto view = std::string_view{buffer};
			auto result0 = CppUtils::Type::Text::Serializer<double>::deserialize(view);
			auto result1 = CppUtils::Type::Text::Serializer<int>::deserialize(view);

			suite.expect(result0.has_value());
			suite.expect(result1.has_value());
			suite.expectEqual(result0.value(), value0);
			suite.expectEqual(result1.value(), value1);
		});
	}};
}
