export module CppUtils.UnitTests.Container.MeshNetwork;

import std;
import CppUtils;

namespace CppUtils::UnitTest::Container::MeshNetwork
{
	auto _ = TestSuite{"Container/MeshNetwork", {"Container/NetworkPtr"}, [](TestSuite& suite) {
		using namespace std::literals;
		using Logger = TestSuite::Logger;
		using StringMeshNodePtr = CppUtils::Container::MeshNodePtr<std::string, std::string>;

		suite.addTest("Initialization", [&] {
			auto _ = StringMeshNodePtr::make("banana");
		});

		suite.addTest("Access value", [&] {
			auto node = StringMeshNodePtr::make("apple");
			auto accessor = node.getValue();
			const auto& value = accessor.value();
			Logger::print("{}", value);
			suite.expectEqual(value, "apple");
		});

		suite.addTest("Copy reference", [&] {
			auto node2 = StringMeshNodePtr{};
			{
				auto node1 = StringMeshNodePtr::make("apple");
				node2 = node1;
			}
			auto accessor = node2.getValue();
			const auto& value = accessor.value();
			Logger::print("{}", value);
			suite.expectEqual(value, "apple");
		});

		suite.addTest("Attach child", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			{
				auto apple = StringMeshNodePtr::make("apple");
				fruit["Elements"] >> apple;
			}

			auto fruitAccessor = fruit.getValue();
			const auto& fruitValue = fruitAccessor.value();
			suite.expectEqual(fruitValue, "fruit");

			auto branches = fruit.at("Elements").value();
			suite.expectEqual(std::size(branches), 1uz);
			{
				auto appleAccessor = branches[0].value().getValue();
				const auto& appleValue = appleAccessor.value();
				Logger::print("{}", appleValue);
				suite.expectEqual(appleValue, "apple");
			}
		});

		suite.addTest("Operator==: Equal nodes", [&] {
			auto node1 = StringMeshNodePtr::make("test");
			auto node2 = node1;
			suite.expectEqual(node1, node2);
		});

		suite.addTest("Operator==: Unequal nodes", [&] {
			auto node1 = StringMeshNodePtr::make("test1");
			auto node2 = StringMeshNodePtr::make("test2");
			suite.expect(node1 != node2);
		});

		suite.addTest("Operator==: Assigned nodes", [&] {
			auto node1 = StringMeshNodePtr::make("test1");
			auto node2 = StringMeshNodePtr::make("test2");
			suite.expect(node1 != node2);
			node2 = node1;
			suite.expectEqual(node1, node2);
		});

		suite.addTest("Operator==: Node and null", [&] {
			auto node1 = StringMeshNodePtr::make("test");
			auto node2 = StringMeshNodePtr{};
			suite.expect(node1 != node2);
		});

		suite.addTest("Detach child", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			auto banana = StringMeshNodePtr::make("banana");
			fruit["Elements"] >> apple;
			fruit["Elements"] >> banana;

			{
				auto fruits = fruit.at("Elements").value();
				suite.expectEqual(std::size(fruits), 2uz);
				{
					auto appleAccessor = fruits[0].value().getValue();
					const auto& value = appleAccessor.value();
					Logger::print("{}", value);
					suite.expectEqual(value, "apple");
				}
				{
					auto bananaAccessor = fruits[1].value().getValue();
					const auto& value = bananaAccessor.value();
					Logger::print("{}", value);
					suite.expectEqual(value, "banana");
				}
			}

			{
				fruit["Elements"] - apple;
				auto fruits = fruit.at("Elements").value();
				suite.expectEqual(std::size(fruits), 1uz);
				{
					auto bananaAccessor = fruits[0].value().getValue();
					const auto& bananaValue = bananaAccessor.value();
					Logger::print("{}", bananaValue);
					suite.expectEqual(bananaValue, "banana");
				}
			}

			{
				fruit["Elements"] - banana;
				auto fruits = fruit.at("Elements").value_or({});
				suite.expectEqual(std::size(fruits), 0uz);
			}
		});

		suite.addTest("Detach children", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			auto banana = StringMeshNodePtr::make("banana");
			fruit["Elements"] >> apple;
			fruit["Elements"] >> banana;

			suite.expectEqual(std::size(fruit.at("Elements").value_or({})), 2uz);

			fruit["Elements"].clear();
			suite.expectEqual(std::size(fruit.at("Elements").value_or({})), 0uz);
		});

		suite.addTest("Detach child with multiple links", [&] {
			auto elements = StringMeshNodePtr::makeRoot("elements");
			auto orange = StringMeshNodePtr::make("orange");

			suite.expectEqual(orange.getDistanceFromRoot(), std::numeric_limits<std::size_t>::max());

			elements["Color"] >> orange;
			elements["Fruit"] >> orange;
			{
				suite.expectEqual(elements.count("Color"), 1uz);
				suite.expectEqual(elements.count("Fruit"), 1uz);
				suite.expectEqual(orange.getDistanceFromRoot(), 1uz);
			}

			elements["Color"] - orange;
			{
				suite.expectEqual(elements.count("Color"), 0uz);
				suite.expectEqual(elements.count("Fruit"), 1uz);
				suite.expectEqual(std::size(elements.at("Fruit").value_or({})), 1uz);
				suite.expectEqual(orange.getDistanceFromRoot(), 1uz);
			}

			elements["Fruit"] - orange;
			{
				suite.expectEqual(elements.count("Color"), 0uz);
				suite.expectEqual(elements.count("Fruit"), 0uz);
				suite.expectEqual(orange.getDistanceFromRoot(), std::numeric_limits<std::size_t>::max());
			}
		});

		suite.addTest("Bidirectional link", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] & apple["Categories"];

			{
				auto elements = fruit.at("Elements").value();
				suite.expectEqual(std::size(elements), 1uz);
				{
					auto appleAccessor = elements[0].value().getValue();
					const auto& value = appleAccessor.value();
					Logger::print("fruit elements contains {}", value);
					suite.expectEqual(value, "apple");
				}
			}
			{
				auto categories = apple.at("Categories").value();
				suite.expectEqual(std::size(categories), 1uz);
				{
					auto fruitAccessor = categories[0].value().getValue();
					const auto& value = fruitAccessor.value();
					Logger::print("apple category is {}", value);
					suite.expectEqual(value, "fruit");
				}
			}
		});

		suite.addTest("Bidirectional link (reverse order)", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			apple["Categories"] & fruit["Elements"];

			{
				auto elements = fruit.at("Elements").value();
				suite.expectEqual(std::size(elements), 1uz);
				{
					auto appleAccessor = elements[0].value().getValue();
					const auto& value = appleAccessor.value();
					Logger::print("fruit elements contains {}", value);
					suite.expectEqual(value, "apple");
				}
			}
			{
				auto categories = apple.at("Categories").value();
				suite.expectEqual(std::size(categories), 1uz);
				{
					auto fruitAccessor = categories[0].value().getValue();
					const auto& value = fruitAccessor.value();
					Logger::print("apple category is {}", value);
					suite.expectEqual(value, "fruit");
				}
			}
		});

		suite.addTest("Many", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto banana = StringMeshNodePtr::make("banana");
			auto orangeFruit = StringMeshNodePtr::make("orange");
			auto lemon = StringMeshNodePtr::make("lemon");

			fruit["Elements"] & banana["Categories"];
			fruit["Elements"] & orangeFruit["Categories"];
			fruit["Elements"] & lemon["Categories"];

			auto color = StringMeshNodePtr::makeRoot("color");
			auto orangeColor = StringMeshNodePtr::make("orange");
			auto yellow = StringMeshNodePtr::make("yellow");

			color["Elements"] & orangeColor["Categories"];
			color["Elements"] & yellow["Categories"];

			banana["Colors"] & yellow["Elements"];
			orangeFruit["Colors"] & orangeColor["Elements"];
			lemon["Colors"] & yellow["Elements"];

			{
				auto fruits = fruit.at("Elements").value();
				suite.expectEqual(std::size(fruits), 3uz);
				for (auto node : fruits)
				{
					suite.expectEqual(std::size(node.at("Categories").value_or({})), 1uz);
					auto categoryAccessor = node["Categories"][0].value().getValue();
					const auto& categoryValue = categoryAccessor.value();
					suite.expectEqual(categoryValue, "fruit");

					suite.expectEqual(std::size(node.at("Colors").value_or({})), 1uz);
					auto colorAccessor = node["Colors"][0].value().getValue();
					auto fruitAccessor = node.getValue();
					const auto& colorValue = colorAccessor.value();
					const auto& fruitValue = fruitAccessor.value();

					Logger::print("{} is a {} {}", fruitValue, colorValue, categoryValue);
				}
			}
		});

		suite.addTest("Attach (operator>>)", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] >> apple;

			const auto& elements = fruit.at("Elements").value_or({});
			suite.expectEqual(std::size(elements), 1uz);
			suite.expectEqual(elements[0].value().getValue().value(), "apple");
		});

		suite.addTest("Chaining (operator>>)", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");
			auto child1 = StringMeshNodePtr::make("child1");
			auto child2 = StringMeshNodePtr::make("child2");

			root["Branch1"] >> child1["Branch2"] >> child2;

			const auto& branch1Children = root.at("Branch1").value_or({});
			suite.expectEqual(std::size(branch1Children), 1uz);
			suite.expectEqual(branch1Children[0].value().getValue().value(), "child1");

			const auto& branch2Children = branch1Children[0].value().at("Branch2").value_or({});
			suite.expectEqual(std::size(branch2Children), 1uz);
			suite.expectEqual(branch2Children[0].value().getValue().value(), "child2");
		});

		suite.addTest("Unlink (operator-)", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");
			auto child = StringMeshNodePtr::make("child");
			root["Branch"] >> child;
			suite.expectEqual(std::size(root.at("Branch").value_or({})), 1uz);

			root["Branch"] - child;
			suite.expectEqual(std::size(root.at("Branch").value_or({})), 0uz);
		});

		suite.addTest("Bidirectional link (operator&)", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] & apple["Categories"];

			const auto& elements = fruit.at("Elements").value_or({});
			suite.expectEqual(std::size(elements), 1uz);
			suite.expectEqual(elements[0].value().getValue().value(), "apple");

			const auto& categories = apple.at("Categories").value_or({});
			suite.expectEqual(std::size(categories), 1uz);
			suite.expectEqual(categories[0].value().getValue().value(), "fruit");
		});

		suite.addTest("Bidirectional unlink (operator/)", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] & apple["Categories"];

			suite.expectEqual(std::size(fruit.at("Elements").value_or({})), 1uz);
			suite.expectEqual(std::size(apple.at("Categories").value_or({})), 1uz);

			fruit["Elements"] / apple["Categories"];

			suite.expectEqual(std::size(fruit.at("Elements").value_or({})), 0uz);
			suite.expectEqual(std::size(apple.at("Categories").value_or({})), 0uz);
		});

		suite.addTest("Get value", [&] {
			auto node = StringMeshNodePtr::make("apple");
			auto accessor = node.getValue();
			suite.expectEqual(accessor.value(), "apple");
		});

		suite.addTest("Set value", [&] {
			auto node = StringMeshNodePtr::make("initial");
			node.setValue("updated");
			auto accessor = node.getValue();
			suite.expectEqual(accessor.value(), "updated");
		});

		suite.addTest("Contains", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] >> apple;
			suite.expect(fruit.contains("Elements"));
			fruit["Elements"] - apple;
			suite.expect(not fruit.contains("Elements"));
		});

		suite.addTest("Count", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");
			auto child = StringMeshNodePtr::make("child");
			suite.expectEqual(root.count("Branch"), 0uz);
			root["Branch"] >> child;
			suite.expectEqual(root.count("Branch"), 1uz);
			root["Branch"] - child;
			suite.expectEqual(root.count("Branch"), 0uz);
		});

		suite.addTest("Branch size", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");
			auto child1 = StringMeshNodePtr::make("child1");
			auto child2 = StringMeshNodePtr::make("child2");
			root["Branch"] >> child1;
			root["Branch"] >> child2;

			suite.expectEqual(std::size(root.at("Branch").value_or({})), 2uz);
		});

		suite.addTest("Branch stays live after construction", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			{
				auto apple = StringMeshNodePtr::make("apple");
				auto branch = fruit["Elements"];
				branch >> apple;
			}
			{
				const auto branch = fruit["Elements"];
				suite.expectEqual(std::size(branch), 1uz);
				suite.expectEqual(branch.front().value().getValue().value(), "apple");
			}
		});

		suite.addTest("Clear branch", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");
			auto child = StringMeshNodePtr::make("child");
			root["Branch"] >> child;
			suite.expectEqual(std::size(root.at("Branch").value_or({})), 1uz);

			root["Branch"].clear();
			suite.expect(not root.contains("Branch"));
		});

		suite.addTest("Get node", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] >> apple;

			auto node = fruit["Elements"][0];
			suite.expect(node.has_value());
			suite.expectEqual(node.value().getValue().value(), "apple");
		});

		suite.addTest("Get node: Newly created branch", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");

			auto invalidKeyExpected = root["Branch"][0];

			suite.expect(not invalidKeyExpected);
			suite.expectEqual(invalidKeyExpected.error(), "Branch index out of bounds"sv);
		});

		suite.addTest("Get node: Invalid index", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] >> apple;

			auto invalidIndexExpected = fruit["Elements"][1];

			suite.expect(not invalidIndexExpected);
			suite.expectEqual(invalidIndexExpected.error(), "Branch index out of bounds"sv);
		});

		suite.addTest("Get node: Invalid node", [&] {
			auto emptyNode = StringMeshNodePtr{};

			suite.expectThrow<std::runtime_error>([&] {
				auto _ = emptyNode["Branch"];
			});
		});

		suite.addTest("Get nodes", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			auto banana = StringMeshNodePtr::make("banana");
			fruit["Elements"] >> apple;
			fruit["Elements"] >> banana;

			auto children = std::vector<StringMeshNodePtr>{};
			for (const auto& node : fruit["Elements"])
				children.push_back(node);

			suite.expectEqual(std::size(children), 2uz);
			suite.expectEqual(children[0].getValue().value(), "apple");
			suite.expectEqual(children[1].getValue().value(), "banana");
		});

		suite.addTest("Get nodes: Non-existent branch", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");

			auto children = std::vector<StringMeshNodePtr>{};
			for (const auto& child : root["NonExistentBranch"])
				children.push_back(child);

			suite.expect(std::empty(children));
		});

		suite.addTest("Get nodes: Invalid node", [&] {
			auto emptyNode = StringMeshNodePtr{};

			suite.expectThrow<std::runtime_error>([&] {
				auto _ = emptyNode["Branch"];
			});
		});

		suite.addTest("at()", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			fruit["Elements"] >> apple;

			const auto branch = fruit.at("Elements");

			suite.expect(branch.has_value());
			suite.expectEqual(std::size(branch.value()), 1uz);
			suite.expectEqual(branch.value()[0].value().getValue().value(), "apple");
		});

		suite.addTest("at(): Non-existent branch", [&] {
			const auto root = StringMeshNodePtr::makeRoot("root");
			auto branch = root.at("NonExistentBranch");
			suite.expect(not branch.has_value());
			suite.expectEqual(branch.error(), "MeshNodePtr::at(): Key not found"sv);
		});

		suite.addTest("at(): Invalid node", [&] {
			auto node = StringMeshNodePtr{};
			auto branch = node.at("Branch");
			suite.expect(not branch.has_value());
			suite.expectEqual(branch.error(), "MeshNodePtr::at(): Invalid MeshNodePtr"sv);
		});

		suite.addTest("Get first node", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			auto banana = StringMeshNodePtr::make("banana");
			fruit["Elements"] >> apple;
			fruit["Elements"] >> banana;

			auto node = fruit["Elements"].front();
			suite.expect(node.has_value());
			suite.expectEqual(node.value().getValue().value(), "apple");
		});

		suite.addTest("Get last node", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			auto apple = StringMeshNodePtr::make("apple");
			auto banana = StringMeshNodePtr::make("banana");
			fruit["Elements"] >> apple;
			fruit["Elements"] >> banana;

			auto node = fruit["Elements"].back();
			suite.expect(node.has_value());
			suite.expectEqual(node.value().getValue().value(), "banana");
		});

		suite.addTest("Random access iterator", [&] {
			auto fruit = StringMeshNodePtr::makeRoot("fruit");
			{
				auto apple = StringMeshNodePtr::make("apple");
				auto banana = StringMeshNodePtr::make("banana");
				auto orange = StringMeshNodePtr::make("orange");
				fruit["Elements"] >> apple;
				fruit["Elements"] >> banana;
				fruit["Elements"] >> orange;
			}

			auto branch = fruit["Elements"];
			auto it = std::begin(branch);

			suite.expectEqual((*it).getValue().value(), "apple");
			suite.expectEqual((*(it + 2)).getValue().value(), "orange");
			suite.expectEqual((it[1]).getValue().value(), "banana");

			it += 2;
			suite.expectEqual((*it).getValue().value(), "orange");
			it -= 1;
			suite.expectEqual((*it).getValue().value(), "banana");

			suite.expect(it < std::cend(branch));
			suite.expectEqual(std::cend(branch) - std::cbegin(branch), 3);
		});

		suite.addTest("Get branches", [&] {
			auto root = StringMeshNodePtr::makeRoot("root");
			auto child1 = StringMeshNodePtr::make("child1");
			auto child2 = StringMeshNodePtr::make("child2");
			auto child3 = StringMeshNodePtr::make("child3");

			root["A"] >> child1;
			root["B"] >> child2;
			root["B"] >> child3;

			auto branchesAccessor = root.getBranches();
			const auto& branches = branchesAccessor.value();

			suite.expectEqual(std::size(branches), 2uz);
			suite.expect(branches.contains("A"));
			suite.expect(branches.contains("B"));

			auto aBranches = branches.at("A")->sharedAccess();
			suite.expectEqual(std::size(aBranches.value()), 1uz);

			auto bBranches = branches.at("B")->sharedAccess();
			suite.expectEqual(std::size(bBranches.value()), 2uz);
		});
	}};
}
