export module CppUtils.UnitTests.Language.MetaCircularParser;

import std;
import CppUtils;

namespace CppUtils::UnitTest::Language::MetaCircularParser
{
	auto _ = TestSuite{
		"Language/MetaCircularParser",
		{"Logger", "Container/MeshNetwork"},
		[](TestSuite& suite) {
		using namespace std::literals;
		using namespace CppUtils::String::Literals;
		using Logger = TestSuite::Logger;
		using MetaCircularVirtualMachine = CppUtils::Language::MetaCircularVirtualMachine;
		using MeshNodePtr = MetaCircularVirtualMachine::MeshNodePtr;

		suite.addTest("Length function", [&] {
			auto interpreter = CppUtils::Language::MetaCircularParser{"Hello"sv};
			auto lengthNode = MeshNodePtr::makeRoot(0uz);

			auto lengthInstruction = MeshNodePtr::makeRoot("length"_token);
			lengthInstruction["length"_token] >> lengthNode;

			const auto status = interpreter(lengthInstruction);
			if (not status)
				Logger::print<"error">("Error: {}", status.error());

			suite.expect(status);
			suite.expectEqual(lengthNode.getValue().value(), 5uz);
		});

		suite.addTest("Read function", [&] {
			auto interpreter = CppUtils::Language::MetaCircularParser{"ABC"sv};
			auto charNode = MeshNodePtr::makeRoot(0uz);
			auto positionNode = MeshNodePtr::make(0uz);

			auto readInstruction = MeshNodePtr::makeRoot("read"_token);
			readInstruction["char"_token] >> charNode;
			readInstruction["position"_token] >> positionNode;

			{
				auto result = interpreter(readInstruction);
				if (not result)
					Logger::print<"error">("Error: {}", result.error());

				suite.expect(result);
				suite.expectEqual(charNode.getValue().value(), static_cast<std::size_t>('A'));
			}
			positionNode.setValue(1uz);
			{
				auto result = interpreter(readInstruction);
				if (not result)
					Logger::print<"error">("Error: {}", result.error());

				suite.expect(result);
				suite.expectEqual(charNode.getValue().value(), static_cast<std::size_t>('B'));
			}
		});

		suite.addTest("Read at end of input", [&] {
			auto interpreter = CppUtils::Language::MetaCircularParser{"A"sv};

			auto readInstruction = MeshNodePtr::makeRoot("read"_token);
			readInstruction["char"_token] >> MeshNodePtr::make(0uz);
			readInstruction["position"_token] >> MeshNodePtr::make(1uz);

			auto result = interpreter(readInstruction);
			suite.expect(not result);
			suite.expectEqual(result.error(), "read: End of input"sv);
		});

		suite.addTest("Iterative hash", [&] {
			constexpr auto source = "TestString"sv;
			auto interpreter = CppUtils::Language::MetaCircularParser{source};

			auto currentHashNode = MeshNodePtr::makeRoot(CppUtils::Type::HashOffset);
			{
				auto charNode = MeshNodePtr::makeRoot(0uz);
				auto positionNode = MeshNodePtr::makeRoot(0uz);
				auto lengthNode = MeshNodePtr::makeRoot(0uz);
				auto resultNode = MeshNodePtr::makeRoot(0uz);
				auto oneNode = MeshNodePtr::makeRoot(1uz);

				auto length = MeshNodePtr::makeRoot("length"_token);
				length["length"_token] >> lengthNode;

				auto lessThan = length["next"_token] >> MeshNodePtr::make("<"_token);
				lessThan["lhs"_token] >> positionNode;
				lessThan["rhs"_token] >> lengthNode;
				lessThan["result"_token] >> resultNode;

				auto jump = lessThan["next"_token] >> MeshNodePtr::make("jump"_token);
				jump["condition"_token] >> resultNode;

				auto read = jump["next"_token] >> MeshNodePtr::make("read"_token);
				read["position"_token] >> positionNode;
				read["char"_token] >> charNode;

				auto hash = read["next"_token] >> MeshNodePtr::make("hash"_token);
				hash["char"_token] >> charNode;
				hash["accumulator"_token] >> currentHashNode;
				hash["hash"_token] >> currentHashNode;

				auto increment = hash["next"_token] >> MeshNodePtr::make("+"_token);
				increment["lhs"_token] >> positionNode;
				increment["rhs"_token] >> oneNode;
				increment["result"_token] >> positionNode;
				increment["next"_token] >> length;

				auto result = interpreter(length);
				if (not result)
					Logger::print<"error">("Error: {}", result.error());

				suite.expect(result);
			}

			suite.expectEqual(currentHashNode.getValue().value(), CppUtils::Type::hash(source));
		});

		suite.addTest("Iterative hash function", [&] {
			constexpr auto source = "TestString"sv;
			auto interpreter = CppUtils::Language::MetaCircularParser{source};

			auto result = interpreter("parseToken"_token);
			if (not result)
				Logger::print<"error">("Error: {}", result.error());

			suite.expect(result);
			auto parseToken = interpreter.get("parseToken"_token);
			suite.expect(parseToken);
			suite.expectEqual(parseToken.value()["result"_token].front()->getValue().value(), CppUtils::Type::hash(source));
		});

		suite.addTest("Set function", [&] {
			auto interpreter = CppUtils::Language::MetaCircularParser{""sv};
			auto targetNode = MeshNodePtr::makeRoot(0uz);
			auto instruction = MeshNodePtr::makeRoot("set"_token);
			instruction["target"_token] >> targetNode;
			instruction["value"_token] >> MeshNodePtr::make(42uz);

			auto result = interpreter(instruction);
			suite.expect(result);
			suite.expectEqual(targetNode.getValue().value(), 42uz);
		});
	}};
}
